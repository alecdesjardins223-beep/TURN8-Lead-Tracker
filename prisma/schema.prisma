// TURN8 Lead Tracker — Prisma Schema (Phase 1 Foundation)
//
// Design principles:
//   - Leads are segment-aware, not tied to a single ICP
//   - Playbooks are reusable and linked to search profiles
//   - Auth is NextAuth-compatible with role support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth (NextAuth v4 required tables)
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// Users & Roles
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  assignedLeads  Lead[]          @relation("AssignedLeads")
  playbookOwner  Playbook[]
  searchProfiles SearchProfile[]
}

// ---------------------------------------------------------------------------
// Lead Archetypes
// Extensible: add new values without a schema change to Lead itself
// ---------------------------------------------------------------------------

enum LeadArchetype {
  FOUNDER
  EXECUTIVE
  BOARD_MEMBER
  DONOR
  FOUNDATION_PARTICIPANT
  FAMILY_OFFICE_PROFESSIONAL
  INCORPORATED_PROFESSIONAL
  OTHER
}

enum LeadStatus {
  IDENTIFIED
  RESEARCHED
  OUTREACH_READY
  CONTACTED
  ENGAGED
  CONVERTED
  ARCHIVED
}

// ---------------------------------------------------------------------------
// Playbooks
// A playbook defines the outreach strategy for a given segment
// ---------------------------------------------------------------------------

model Playbook {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  archetype   LeadArchetype
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  searchProfiles SearchProfile[]
  leads          Lead[]
}

// ---------------------------------------------------------------------------
// Search Profiles
// A saved search/segment configuration that generates leads
// ---------------------------------------------------------------------------

model SearchProfile {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  archetype   LeadArchetype
  filters     Json     @default("{}")  // flexible filter bag: titles, industries, geographies, etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  playbookId String?
  playbook   Playbook? @relation(fields: [playbookId], references: [id])

  leads Lead[]
}

// ---------------------------------------------------------------------------
// Leads
// The central record — a person being tracked through a playbook
// ---------------------------------------------------------------------------

model Lead {
  id          String        @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  linkedinUrl String?
  title       String?
  company     String?
  location    String?
  archetype   LeadArchetype
  status      LeadStatus    @default(IDENTIFIED)
  notes       String?       @db.Text
  metadata    Json          @default("{}")  // archetype-specific extra fields
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assignedToId String?
  assignedTo   User?   @relation("AssignedLeads", fields: [assignedToId], references: [id])

  playbookId String?
  playbook   Playbook? @relation(fields: [playbookId], references: [id])

  searchProfileId String?
  searchProfile   SearchProfile? @relation(fields: [searchProfileId], references: [id])

  activities LeadActivity[]

  @@index([archetype])
  @@index([status])
  @@index([assignedToId])
}

// ---------------------------------------------------------------------------
// Lead Activity Log
// Append-only history of actions taken on a lead
// ---------------------------------------------------------------------------

enum ActivityType {
  NOTE
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_REPLIED
  CALL
  STATUS_CHANGE
  ASSIGNMENT_CHANGE
}

model LeadActivity {
  id        String       @id @default(cuid())
  leadId    String
  type      ActivityType
  body      String?      @db.Text
  metadata  Json         @default("{}")
  createdAt DateTime     @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}
