# ──────────────────────────────────────────────
# TURN8 Lead Tracker — Environment Variables
# Copy this file to .env.local and fill in values
# ──────────────────────────────────────────────

# PostgreSQL connection string
# Local dev: postgresql://USER:PASSWORD@localhost:5432/turn8_dev
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/turn8_dev"

# NextAuth
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-secret"

# Email provider (for magic-link auth)
# Using SMTP: smtp://user:pass@smtp.example.com:587
EMAIL_SERVER="smtp://user:pass@smtp.host:587"
EMAIL_FROM="TURN8 Lead Tracker <noreply@turn8.io>"

# ── Future integrations (Phase 2+) ──────────────
# PERPLEXITY_API_KEY=""
# RESEND_API_KEY=""
